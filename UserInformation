# ==========================================
# 0. 유틸리티 함수 (공백 및 줄바꿈 제거, 소문자화)
# ==========================================
def clean_string(s):
    if not s:
        return ""
    # 모든 공백, 줄바꿈 문자 등을 제거하고 소문자로 통일 (대소문자/줄바꿈 무시 매칭용)
    return re.sub(r'\s+', '', str(s)).lower()

def get_display_header(h):
    # UI 표출용: 줄바꿈 문자를 띄어쓰기로 치환 (f-string 내부 백슬래시 에러 방지)
    if not h:
        return ""
    return str(h).replace('\n', ' ').strip()

def find_sheet_by_lenient_name(workbook, target_name):
    target_clean = clean_string(target_name)
    for sheetname in workbook.sheetnames:
        if clean_string(sheetname) == target_clean:
            return workbook[sheetname]
    return None

