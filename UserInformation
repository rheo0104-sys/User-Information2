# 1. 오프라인용 맞춤 내장 달력 팝업 클래스
# ==========================================
class CalendarPopup(tk.Toplevel):
    def __init__(self, parent, target_entry):
        super().__init__(parent)
        self.target_entry = target_entry
        self.title("날짜 선택")
        self.geometry("280x300")
        self.resizable(False, False)
        self.grab_set()  
        
        self.now = datetime.now()
        self.current_year = self.now.year
        self.current_month = self.now.month
        
        self.header_frame = tk.Frame(self)
        self.header_frame.pack(pady=10)
        
        self.prev_btn = ttk.Button(self.header_frame, text="<", width=3, command=self.prev_month)
        self.prev_btn.pack(side=tk.LEFT, padx=5)
        
        self.title_label = tk.Label(self.header_frame, text="", font=("Arial", 12, "bold"))
        self.title_label.pack(side=tk.LEFT, padx=10)
        
        self.next_btn = ttk.Button(self.header_frame, text=">", width=3, command=self.next_month)
        self.next_btn.pack(side=tk.LEFT, padx=5)
        
        self.days_frame = tk.Frame(self)
        self.days_frame.pack()
        
        days = ["일", "월", "화", "수", "목", "금", "토"]
        for idx, day in enumerate(days):
            lbl = tk.Label(self.days_frame, text=day, width=4, fg="red" if idx==0 else "blue" if idx==6 else "black")
            lbl.grid(row=0, column=idx, pady=2)
            
        self.draw_calendar()
        
    def draw_calendar(self):
        for widget in self.days_frame.winfo_children():
            if int(widget.grid_info()["row"]) > 0:
                widget.destroy()
                
        # f-string 오류를 막기 위해 포맷팅 사용 시 백슬래시 배제
        self.title_label.config(text=f"{self.current_year}년 {self.current_month}월")
        
        import calendar
        cal = calendar.TextCalendar(calendar.SUNDAY)
        month_days = cal.monthdayscalendar(self.current_year, self.current_month)
        
        for r_idx, week in enumerate(month_days):
            for c_idx, day in enumerate(week):
                if day == 0:
                    continue
                btn = tk.Button(self.days_frame, text=str(day), width=4, height=1,
                                command=lambda d=day: self.select_date(d))
                btn.grid(row=r_idx+1, column=c_idx, pady=2, padx=2)
                if c_idx == 0: btn.config(fg="red")
                if c_idx == 6: btn.config(fg="blue")
                
    def prev_month(self):
        self.current_month -= 1
        if self.current_month < 1:
            self.current_month = 12
            self.current_year -= 1
        self.draw_calendar()
        
    def next_month(self):
        self.current_month += 1
        if self.current_month > 12:
            self.current_month = 1
            self.current_year += 1
        self.draw_calendar()
        
    def select_date(self, day):
        selected_str = f"{self.current_year}-{self.current_month:02d}-{day:02d}"
        self.target_entry.delete(0, tk.END)
        self.target_entry.insert(0, selected_str)
        self.destroy()

