    def browse_folder(self):
        selected = filedialog.askdirectory(initialdir=self.target_dir)
        if selected:
            self.target_dir = selected
            self.dir_label.config(text=f"현재 폴더: {self.target_dir}")
            self.update_latest_file()

    def update_latest_file(self):
        files = glob.glob(os.path.join(self.target_dir, "*.xlsx"))
        if not files:
            self.file_status_label.config(text="⚠️ 폴더 내에 엑셀(.xlsx) 파일이 존재하지 않습니다.", fg="red")
            self.latest_src_file = ""
            return
            
        self.latest_src_file = max(files, key=os.path.getmtime)
        fname = os.path.basename(self.latest_src_file)
        self.file_status_label.config(text=f"✅ 연동 파일: {fname}", fg="green")
        
        self.load_excel_metadata()
        self.rebuild_main_ui()

    def load_excel_metadata(self):
        if not self.latest_src_file: return
        try:
            wb = openpyxl.load_workbook(self.latest_src_file, data_only=True)
            
            # 1. Site Information 헤더 분석
            ws_site = find_sheet_by_lenient_name(wb, "Site Information")
            if ws_site:
                self.site_headers = [str(cell.value).strip() for cell in ws_site[1] if cell.value]
            else:
                self.site_headers = ["User ID", "SITE_NAME", "SITE_CODE", "Server type", "CONTRACT_DATE", "IRB_APPROVAL_DATE", "REQUEST_DATE"]
            
            # Site 코드-이름 자동 연동 매핑 생성
            self.site_code_name_map.clear()
            self.site_name_code_map.clear()
            if ws_site:
                s_headers_clean = [clean_string(h) for h in self.site_headers]
                idx_code, idx_name = -1, -1
                for idx, h in enumerate(s_headers_clean):
                    if "sitecode" in h: idx_code = idx
                    if "sitename" in h: idx_name = idx
                
                if idx_code != -1 and idx_name != -1:
                    for row in ws_site.iter_rows(min_row=2, values_only=True):
                        if idx_code < len(row) and idx_name < len(row):
                            code_val = str(row[idx_code]).strip() if row[idx_code] is not None else ""
                            name_val = str(row[idx_name]).strip() if row[idx_name] is not None else ""
                            if code_val and name_val:
                                self.site_code_name_map[code_val] = name_val
                                self.site_name_code_map[name_val] = code_val

            # 2. User Information 헤더 분석
            ws_user = find_sheet_by_lenient_name(wb, "User Information")
            if ws_user:
                self.user_headers = [str(cell.value).strip() for cell in ws_user[1] if cell.value]
            else:
                self.user_headers = ["User ID", "SITE_NAME", "SITE_CODE", "Server type", "ROLE", "ACTIVATION_DATE", "TYPE", "REQUEST_DATE"]
            
            # 엑셀 내부 기존의 Role 데이터 파싱 및 고유 목록 추출
            self.parsed_roles = []
            if ws_user and ws_user.max_row >= 2:
                u_headers_clean = [clean_string(h) for h in self.user_headers]
                idx_role = -1
                for idx, h in enumerate(u_headers_clean):
                    if "role" in h:
                        idx_role = idx
                        break
                if idx_role != -1:
                    unique_roles = set()
                    for r_val in ws_user.iter_rows(min_row=2, column=idx_role+1, values_only=True):
                        if r_val[0]:
                            tokens = re.split(r'[\s,]+', str(r_val[0]))
                            for t in tokens:
                                if t.strip(): unique_roles.add(t.strip())
                    self.parsed_roles = sorted(list(unique_roles))
            
            if not self.parsed_roles:
                self.parsed_roles = ["Admin", "User", "Manager", "Reviewer", "Data Ingestor", "Lead Coder"]
                
            wb.close()
        except Exception as e:
            print(f"메타데이터 로드 중 오류 발생: {e}")

