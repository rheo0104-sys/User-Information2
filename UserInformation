                input_dict[header] = ("ROLE_SELECTOR", selected_roles_list)
                
            else:
                ttk.Label(f_box, text=lbl_text).grid(row=r, column=c*2, padx=5, pady=5, sticky=tk.W)
                ent = ttk.Entry(f_box, width=15)
                ent.grid(row=r, column=c*2+1, padx=5, pady=5, sticky=tk.W)
                input_dict[header] = ("TEXT", ent)
                
            c += 1
            if c > 2:
                c = 0; r += 1
                
        if cb_code and cb_name:
            cb_code.bind("<<ComboboxSelected>>", lambda event, cc=cb_code, cn=cb_name: self.on_site_code_changed(cc, cn))
            cb_name.bind("<<ComboboxSelected>>", lambda event, cc=cb_code, cn=cb_name: self.on_site_name_changed(cc, cn))
            
        btn_action_frame = ttk.Frame(f_box)
        btn_action_frame.grid(row=r+1, column=0, columnspan=6, padx=5, pady=10, sticky=tk.E)
        ttk.Button(btn_action_frame, text=f"➕ {type_mode} 대기목록에 추가", command=lambda m=type_mode: self.add_user_to_grid(m)).pack(side=tk.LEFT, padx=5)

    def on_site_code_changed(self, cb_code, cb_name):
        code = cb_code.get()
        if code in self.site_code_name_map:
            cb_name.set(self.site_code_name_map[code])

    def on_site_name_changed(self, cb_code, cb_name):
        name = cb_name.get()
        if name in self.site_name_code_map:
            cb_code.set(self.site_name_code_map[name])

    def open_role_selector(self, display_label, target_list):
        pop = tk.Toplevel(self.root)
        pop.title("ROLE 다중 선택")
        pop.geometry("250x300")
        pop.grab_set()
        
        ttk.Label(pop, text="해당되는 역할을 모두 체크하세요:", font=("Arial", 9, "bold")).pack(pady=10)
        
        chk_frame = ttk.Frame(pop)
        chk_frame.pack(expand=True, fill=tk.BOTH, padx=15)
        
        chk_vars = {}
        for role in self.parsed_roles:
            var = tk.BooleanVar(value=True if role in target_list else False)
            chk_vars[role] = var
            cb = ttk.Checkbutton(chk_frame, text=role, variable=var)
            cb.pack(anchor=tk.W, pady=3)
            
        def confirm_selection():
            target_list.clear()
            for role, var in chk_vars.items():
                if var.get():
                    target_list.append(role)
            if target_list:
                display_label.config(text=", ".join(target_list))
            else:
                display_label.config(text="(선택 없음)")
            pop.destroy()
            
        ttk.Button(pop, text="적용 및 확인", command=confirm_selection).pack(pady=10)

    def add_site_to_grid(self):
        row_values = []
        uid_present = False
        uid_val = ""
        
        for h in self.site_headers:
            if h not in self.site_inputs:
                row_values.append("")
                continue
            mode, widget = self.site_inputs[h]
            if mode == "AUTO_DATE":
                row_values.append(datetime.now().strftime("%Y-%m-%d"))
            elif mode == "COMBO":
                row_values.append(widget.get())
            elif mode in ["CALENDAR", "TEXT"]:
                val = widget.get().strip()
                row_values.append(val)
                if "userid" in clean_string(h):
                    uid_present = True
                    uid_val = val
            else:
                row_values.append("")
                
        if uid_present and not uid_val:
            messagebox.showwarning("필수 입력 누락", "User ID 항목은 반드시 기입해야 합니다.")
            return
            
        self.site_tree.insert("", tk.END, values=row_values)
        
        for h in self.site_headers:
            if h in self.site_inputs:
                mode, widget = self.site_inputs[h]
                if mode in ["CALENDAR", "TEXT"]:
                    widget.delete(0, tk.END)

    def add_user_to_grid(self, type_mode):
        inputs = self.user_active_inputs if type_mode == "Active" else self.user_inactive_inputs
        row_values = []
        uid_val = ""
        
        for h in self.user_headers:
            if h not in inputs:
                row_values.append("")
                continue
            info = inputs[h]
            mode = info[0]
            
            if mode == "AUTO_DATE":
                row_values.append(datetime.now().strftime("%Y-%m-%d"))
            elif mode == "AUTO_TYPE":
                row_values.append(type_mode)
            elif mode == "COMBO":
                row_values.append(info[1].get())
            elif mode in ["SITE_CODE_CB", "SITE_NAME_CB"]:
                row_values.append(info[1].get())
            elif mode == "CALENDAR":
                row_values.append(info[1].get().strip())
            elif mode == "ROLE_SELECTOR":
                row_values.append(", ".join(info[1]))
            elif mode == "TEXT":
                val = info[1].get().strip()
                row_values.append(val)
                if "userid" in clean_string(h):
                    uid_val = val
                    
        if not uid_val:
            messagebox.showwarning("필수 입력 누락", "User ID 항목은 필수 기입 대상입니다.")
            return
            
        self.user_tree.insert("", tk.END, values=row_values)
        
        for h in self.user_headers:
            if h in inputs:
                info = inputs[h]
                mode = info[0]
                if mode == "TEXT" or mode == "CALENDAR":
                    info[1].delete(0, tk.END)
                elif mode in ["SITE_CODE_CB", "SITE_NAME_CB"]:
                    info[1].set("")
                elif mode == "ROLE_SELECTOR":
                    info[1].clear()

    def delete_selected_grid(self, tree_widget):
        for item in tree_widget.selection():
            tree_widget.delete(item)

    def submit_site_data(self):
        self.save_tree_to_excel("Site Information", self.site_tree, self.site_headers)

    def submit_user_data(self):
        self.save_tree_to_excel("User Information", self.user_tree, self.user_headers)

    def save_tree_to_excel(self, sheet_name, tree_widget, current_headers):
        self.update_latest_file()
        if not self.latest_src_file:
            messagebox.showerror("오류", "연동 가능한 대상 엑셀 파일이 부재합니다.")
            return
            
        items = tree_widget.get_children()
        if not items:
            messagebox.showwarning("알림", "대기 목록에 업로드할 데이터가 없습니다.")
            return
            
        try:
            wb = openpyxl.load_workbook(self.latest_src_file)
            ws = find_sheet_by_lenient_name(wb, sheet_name)
            
            if ws is None:
                ws = wb.create_sheet(title=sheet_name)
                ws.append(current_headers)
                
            for item in items:
                ws.append([str(x) for x in tree_widget.item(item)["values"]])
                
            wb.save(self.latest_src_file)
            wb.close()
            
            messagebox.showinfo("저장 완료", f"'{sheet_name}'에 {len(items)}건의 데이터가 누적 저장되었습니다.")
            for item in items: tree_widget.delete(item)
            
            self.load_excel_metadata()
            self.rebuild_main_ui()
        except Exception as e:
            messagebox.showerror("엑셀 저장 오류", f"엑셀 파일 쓰기에 실패했습니다:\n{str(e)}")

    def search_integrated_data(self):
        self.update_latest_file()
        search_key = self.ent_search_key.get().strip()
        if not search_key:
            messagebox.showwarning("검색 주의", "조회하려는 User ID를 입력하세요.")
            return
        if not self.latest_src_file:
            messagebox.showerror("오류", "연동 파일이 존재하지 않습니다.")
            return
            
        try:
            wb = openpyxl.load_workbook(self.latest_src_file, data_only=True)
            self.txt_search_result.delete("1.0", tk.END)
            found_flag = False
            
            for s_name in ["Site Information", "User Information"]:
                ws = find_sheet_by_lenient_name(wb, s_name)
                if ws is None: continue
                
                headers_raw = [str(cell.value).strip() for cell in ws[1] if cell.value]
                
                id_idx = -1
                for idx, h in enumerate(headers_raw):
                    if "userid" in clean_string(h):
                        id_idx = idx
                        break
                if id_idx == -1: id_idx = 0
                
                # f-string 밖에서 안전하게 변수 생성
                section_txt = f"★ [{s_name} - 매칭 내역] ★\n"
                sheet_found = False
                
                for row in ws.iter_rows(min_row=2, values_only=True):
                    if id_idx < len(row) and row[id_idx] and clean_string(row[id_idx]) == clean_string(search_key):
                        for h_name, val in zip(headers_raw, row):
                            # 백슬래시 문법 에러를 회피하기 위해 변수 가공을 f-string 외부로 분리
                            clean_h_name = get_display_header(h_name)
                            display_val = val if val is not None else ''
                            section_txt += f" ▫️ {clean_h_name}: {display_val}\n"
                        section_txt += "--------------------------------------\n"
                        sheet_found = True
                        found_flag = True
                        
                if sheet_found:
                    self.txt_search_result.insert(tk.END, section_txt + "\n")
                    
            if not found_flag:
                self.txt_search_result.insert(tk.END, f"❌ 통합 검색 결과 '{search_key}' 유저 ID에 해당되는 정보가 없습니다.")
            wb.close()
        except Exception as e:
            messagebox.showerror("검색 시스템 오류", f"조회 중 에러가 발생했습니다:\n{str(e)}")

